# ============================================================================
# Multi-stage Dockerfile for Secure Payment Platform
# Optimized for minimal attack surface and supply chain security
# ============================================================================

# Stage 1: Build
# Using specific version tag (not :latest) for reproducible builds — SLSA best practice
FROM golang:1.22-alpine AS builder

# Install ca-certificates for HTTPS calls (if needed in the app)
RUN apk add --no-cache ca-certificates git

WORKDIR /build

# Copy go.mod first for dependency caching
COPY go.mod ./

# Copy source code (go.sum will be generated by go mod tidy)
COPY . .

# Download dependencies and generate go.sum
RUN go mod tidy

# Build with security flags:
# - CGO_ENABLED=0: Static binary, no C dependencies
# - -trimpath: Remove local file paths from binary (security)
# - -ldflags: Inject version info + strip debug symbols (-s -w)
ARG VERSION=dev
ARG BUILD_TIME=unknown
ARG GIT_COMMIT=unknown

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -trimpath \
    -ldflags="-s -w \
        -X main.version=${VERSION} \
        -X main.buildTime=${BUILD_TIME} \
        -X main.gitCommit=${GIT_COMMIT}" \
    -o /build/server .

# ============================================================================
# Stage 2: Runtime
# Using distroless for maximum security:
# - No shell (can't exec into container)
# - No package manager (can't install tools)
# - Minimal OS packages = minimal CVEs in SBOM
# ============================================================================
FROM gcr.io/distroless/static-debian12:nonroot

# Labels for OCI image metadata (used by scanners and registries)
LABEL org.opencontainers.image.title="secure-payment-platform" \
      org.opencontainers.image.description="SLSA Level 3 secured payment service" \
      org.opencontainers.image.source="https://github.com/rap1p1/secure-payment-platform" \
      org.opencontainers.image.vendor="rap1p1" \
      org.opencontainers.image.licenses="MIT"

# Copy the binary from builder
COPY --from=builder /build/server /server

# Run as non-root user (UID 65532 = nonroot in distroless)
USER nonroot:nonroot

# Expose the application port
EXPOSE 8080

# NOTE: No HEALTHCHECK here — distroless has no shell.
# Kubernetes liveness/readiness probes handle health checks instead.

ENTRYPOINT ["/server"]
